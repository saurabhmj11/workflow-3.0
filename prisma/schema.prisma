// ─── OpenWorkflow Prisma Schema ────────────────────
// AI Workflow Operating System persistence layer
//
// ─── Switching Database Provider ──────────────────
// This schema works with both SQLite and PostgreSQL.
// No SQLite-specific features are used, so switching is seamless.
//
// To switch to PostgreSQL:
//   Option A: Run the switcher script
//     ./scripts/db-switch.sh postgresql
//
//   Option B: Manual steps
//     1. Change provider below: "sqlite" → "postgresql"
//     2. Update .env: DATABASE_URL="postgresql://user:password@localhost:5432/openworkflow?schema=public"
//     3. Run: npx prisma generate && npx prisma db push
//
// To switch back to SQLite:
//   ./scripts/db-switch.sh sqlite
//
// For Docker-based PostgreSQL:
//   docker compose -f docker-compose.dev.yml up -d
//   ./scripts/setup-postgres.sh
// ────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth.js v5 Models ──────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  hashedPassword String?
  image          String?
  role           String   @default("USER") // ADMIN, USER, VIEWER
  emailVerified  DateTime?
  accounts       Account[]
  sessions       Session[]
  workflows      Workflow[]
  customerProfiles CustomerProfile[]
  metadata       String?  // JSON: organization settings, notification preferences, etc.
  integrationCredentials IntegrationCredential[]
  notifications    Notification[]
  apiKeys        ApiKey[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Workflow Models ────────────────────────────────

model Workflow {
  id          String   @id @default(cuid())
  name        String   @default("Untitled Workflow")
  description String?
  version     Int      @default(1)
  isActive    Boolean  @default(false)
  metadata    String?  // JSON string
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodes       XmlNode[]
  edges       Edge[]
  executions  Execution[]
  versions    WorkflowVersion[]
  deployments Deployment[]
  webhookTriggers   WebhookTrigger[]
  scheduleTriggers  ScheduleTrigger[]
  emailTriggers     EmailTrigger[]
  formTriggers      FormTrigger[]
  voiceCallTriggers VoiceCallTrigger[]
  whatsAppTriggers  WhatsAppTrigger[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model XmlNode {
  id         String   @id @default(cuid())
  workflowId String
  nodeId     String   // The logical node ID (e.g., "node-1-1234")
  type       String   // NodeType: api, webhook, llm, condition, etc.
  label      String
  category   String   // NodeCategory: trigger, logic, ai, human, action
  config     String   @default("{}") // JSON string of config
  positionX  Float    @default(0)
  positionY  Float    @default(0)
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, nodeId])
}

model Edge {
  id           String   @id @default(cuid())
  workflowId   String
  source       String   // source nodeId
  target       String   // target nodeId
  sourceHandle String   @default("default")
  targetHandle String   @default("input")
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model Execution {
  id              String     @id @default(cuid())
  workflowId      String
  runId           String     @unique
  status          String     @default("running") // running, success, error, paused, awaiting_approval
  triggeredBy     String     @default("api")
  input           String?    // JSON
  output          String?    // JSON
  steps           String     @default("[]") // JSON array of NodeExecutionStep
  totalDurationMs Int        @default(0)
  totalCostUsd    Float      @default(0)
  error           String?
  workflow        Workflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  startedAt       DateTime   @default(now())
  finishedAt      DateTime?
}

model MCPServer {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String   @default("sse") // sse, streamable-http, stdio
  description String?
  status      String   @default("disconnected") // connected, disconnected, error
  headers     String?  // JSON string of custom headers
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tools       MCPTool[]
}

model MCPTool {
  id          String    @id @default(cuid())
  serverId    String
  name        String
  description String?
  inputSchema String?   // JSON Schema string
  annotations String?   // JSON string
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  server      MCPServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
}

model WorkflowVersion {
  id          String   @id @default(cuid())
  workflowId  String
  version     Int
  name        String
  description String?
  snapshot    String   // JSON string of { nodes: NodeDefinition[], edges: EdgeDefinition[] }
  changeNote  String?
  createdAt   DateTime @default(now())

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
}

// ─── Agent Memory Layer ──────────────────────────
// Stores customer context, interaction history, and sentiment data
// so AI employees can reference past interactions

model CustomerProfile {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  company       String?
  tier          String   @default("free") // free, starter, pro, enterprise
  avatarUrl     String?
  metadata      String?  // JSON: arbitrary customer data (purchase history, preferences, etc.)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  interactions  Interaction[]
  sentimentLogs SentimentLog[]
  memoryNotes   MemoryNote[]
}

model Interaction {
  id           String   @id @default(cuid())
  customerId   String
  type         String   // email, chat, ticket, call, webhook
  subject      String?
  content      String   // The body/content of the interaction
  summary      String?  // AI-generated summary
  sentiment    String?  // positive, negative, neutral, mixed
  confidence   Float?   // AI confidence in the classification
  status       String   @default("new") // new, in_progress, resolved, escalated, closed
  priority     String   @default("normal") // low, normal, high, critical
  assignee     String?  // Who/what handled this (AI agent name or human)
  resolution   String?  // How it was resolved
  tags         String?  // JSON array of tags
  metadata     String?  // JSON: additional data (ticket ID, channel, etc.)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resolvedAt   DateTime?

  customer     CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model SentimentLog {
  id          String   @id @default(cuid())
  customerId  String
  source      String   // interaction_id, manual, batch_analysis
  sentiment   String   // positive, negative, neutral, mixed
  score       Float    // -1.0 to 1.0
  confidence  Float    // 0 to 1.0
  notes       String?
  createdAt   DateTime @default(now())

  customer    CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ─── Memory Notes & Knowledge Extraction ────────
// AI-extracted facts, preferences, and insights about customers
// These are short, structured notes that the AI employee "remembers"

model MemoryNote {
  id          String   @id @default(cuid())
  customerId  String
  category    String   // preference, fact, insight, warning, commitment
  content     String   // The extracted knowledge (e.g., "Prefers email over phone")
  source      String   @default("ai_extraction") // ai_extraction, manual, interaction
  sourceId    String?  // ID of the originating interaction or extraction run
  confidence  Float    @default(1.0) // 0-1, how confident we are in this note
  isActive    Boolean  @default(true) // Soft-delete / supersede
  tags        String?  // JSON array of tags
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ─── Customer Segments ──────────────────────────
// Group customers by behavior, tier, sentiment, etc.

model CustomerSegment {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("auto") // auto, manual
  rules       String   // JSON: segment rules/filters (e.g., {"tier": "enterprise", "minInteractions": 5})
  color       String?  // UI color for the segment badge
  memberCount Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Approval Persistence ────────────────────────
// Persists approval requests so they survive page refresh

model ApprovalRecord {
  id           String    @id @default(cuid())
  runId        String
  nodeId       String
  workflowId   String
  status       String    @default("pending") // pending, approved, rejected, expired
  assignee     String?
  context      String    // JSON: input, nodeLabel, nodeType, nodeOutputs
  notes        String?
  slaDeadline  DateTime?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
}

// ─── Integration Credentials ─────────────────────
// Stores OAuth tokens and API keys for connected integrations

model IntegrationCredential {
  id             String   @id @default(cuid())
  integrationId  String   // gmail, slack, zendesk, hubspot, outlook
  accessToken    String?
  refreshToken   String?
  apiKey         String?
  expiresAt      DateTime?
  metadata       String?  // JSON: scopes, account info, etc.
  status         String   @default("active") // active, expired, revoked
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([integrationId])
}

// ─── Real-Time Triggers ─────────────────────────
// Webhook, Schedule, and Email trigger infrastructure

model WebhookTrigger {
  id           String   @id @default(cuid())
  workflowId   String
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  triggerId    String   @unique  // Unique ID used in the webhook URL
  secret       String?            // Optional HMAC secret for signature verification
  description  String?
  isActive     Boolean  @default(true)
  lastTriggeredAt DateTime?
  triggerCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ScheduleTrigger {
  id             String   @id @default(cuid())
  workflowId     String
  workflow       Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  cronExpression String            // e.g., "*/5 * * * *"
  timezone       String   @default("UTC")
  isActive       Boolean  @default(true)
  lastTriggeredAt DateTime?
  triggerCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model EmailTrigger {
  id           String   @id @default(cuid())
  workflowId   String
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  host         String            // IMAP server host
  port         Int      @default(993)
  username     String            // Email address
  password     String            // App password (encrypted at rest)
  mailbox      String   @default("INBOX")
  pollInterval Int      @default(30)  // seconds
  isActive     Boolean  @default(true)
  lastTriggeredAt DateTime?
  triggerCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Form Trigger ─────────────────────────────────
// Public form triggers that accept submissions and execute workflows

model FormTrigger {
  id              String    @id @default(cuid())
  formId          String    @unique @default(cuid())
  name            String
  workflowId      String
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fields          String    @default("[]")  // JSON array of field definitions
  isActive        Boolean   @default(true)
  submitCount     Int       @default(0)
  lastSubmittedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Voice Call Trigger ──────────────────────────
// Twilio / Vonage voice call triggers that accept inbound calls

model VoiceCallTrigger {
  id              String    @id @default(cuid())
  triggerId       String    @unique @default(cuid())
  name            String
  workflowId      String
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  provider        String    @default("twilio") // twilio, vonage, etc.
  phoneNumber     String?   // The phone number to receive calls on
  webhookUrl      String?   // The URL for the voice provider to call
  welcomeMessage  String?   // TTS message to play when call connects
  recordCall      Boolean   @default(false)
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  triggerCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── WhatsApp Trigger ────────────────────────────
// Meta / Twilio / 360dialog WhatsApp message triggers

model WhatsAppTrigger {
  id              String    @id @default(cuid())
  triggerId       String    @unique @default(cuid())
  name            String
  workflowId      String
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  provider        String    @default("meta") // meta, twilio, 360dialog
  phoneNumberId   String?   // Meta WhatsApp Business phone number ID
  webhookVerifyToken String? // Token for webhook verification
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  triggerCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model TriggerLog {
  id          String   @id @default(cuid())
  triggerType String   // webhook, schedule, email, form
  triggerId   String   // Reference to the specific trigger
  workflowId  String
  payload     String   // JSON string of the trigger payload
  status      String   // success, error
  error       String?
  duration    Int?     // Processing time in ms
  createdAt   DateTime @default(now())
}

// ─── Audit Trail ──────────────────────────────────
// Tracks all significant actions across the platform

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  userEmail    String?
  action       String   // workflow.created, workflow.updated, workflow.deleted, workflow.executed, approval.approved, approval.rejected, integration.connected, integration.disconnected, user.login, user.registered, trigger.created, trigger.deleted, api_key.created, api_key.revoked
  resource     String   // workflow, execution, approval, integration, trigger, user, api_key
  resourceId   String?
  resourceName String?
  status       String   @default("success") // success, failure
  ipAddress    String?
  userAgent    String?
  details      String?  // JSON: additional context
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resource, resourceId])
}

// ─── Notification Center ─────────────────────────
// Stores in-app notifications for users
// Supports categories: execution, approval, trigger, integration, system

model Notification {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // execution_complete, approval_needed, trigger_fired, integration_connected, error_alert, info
  title       String
  message     String
  category    String    // execution, approval, trigger, integration, system
  priority    String    @default("normal") // low, normal, high, critical
  isRead      Boolean   @default(false)
  actionUrl   String?   // URL to navigate to when clicked
  metadata    String?   // JSON: additional data (runId, workflowId, etc.)
  createdAt   DateTime  @default(now())
  readAt      DateTime?

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── API Keys ──────────────────────────────────────
// API keys for programmatic access to the OpenWorkflow API

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    // SHA-256 hash of the key
  keyPrefix   String    // First 8 chars for display (e.g., "owf_1a2b")
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([keyPrefix])
}

// ─── Rate Limiting ──────────────────────────────────
// Persistent rate limit entries for cross-instance rate limiting

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  resetTime DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Deployment Environments & Deployments ────────
// Manages workflow promotion between dev/staging/production
// with version tracking and rollback support

model DeploymentEnvironment {
  id          String   @id @default(cuid())
  name        String   // dev, staging, production
  slug        String   @unique // dev, staging, production
  description String?
  color       String   @default("#6B7280") // UI color
  isDefault   Boolean  @default(false)
  requiresApproval Boolean @default(false) // Promotion to this env requires approval
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deployments Deployment[]
}

model Deployment {
  id              String   @id @default(cuid())
  workflowId      String
  workflow        Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     DeploymentEnvironment @relation(fields: [environmentId], references: [id])
  version         Int      // Snapshot version deployed
  snapshotId      String?  // Reference to WorkflowVersion snapshot
  status          String   @default("deployed") // deployed, promoting, rolled_back, failed
  deployedBy      String?  // userId
  deployedAt      DateTime @default(now())
  promotedFrom    String?  // Previous environment deployment ID
  rollbackData    String?  // JSON: previous deployment snapshot for rollback
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── SSO / SAML Configuration ────────────────────
// Manages SAML and OIDC identity provider configurations
// for enterprise single sign-on authentication

model SSOConfiguration {
  id              String   @id @default(cuid())
  name            String
  provider        String   // saml, oidc, okta, azure-ad, google-workspace
  enabled         Boolean  @default(false)

  // SAML-specific
  samlEntryPoint  String?  // Identity Provider SSO URL
  samlCertificate String?  // IDP certificate (x509)
  samlIssuer      String?  // Entity ID

  // OIDC-specific
  oidcDiscoveryUrl String? // .well-known/openid-configuration
  oidcClientId     String?
  oidcClientSecret String?

  // Domain restriction
  allowedDomains   String?  // JSON array: ["company.com"]

  // Auto-provisioning
  autoProvision    Boolean  @default(true)
  defaultRole      String   @default("USER")

  metadata         String?  // JSON: additional provider-specific config
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Site Configuration ──────────────────────────
// Key-value store for platform-wide settings (white-label config, embed tokens, etc.)

model SiteConfig {
  key       String   @id  // e.g., "whitelabel", "embed_token:abc123"
  value     String   // JSON string of the configuration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
